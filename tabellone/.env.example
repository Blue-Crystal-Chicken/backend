# ============================================================================
#  Tabellone Ordini — configurazione ambiente
#  Copia questo file in ".env" e modifica solo ciò che ti serve.
# ============================================================================

# ── Backend (cambia SOLO la porta per puntare a un altro ambiente) ──────────
VITE_API_PROTOCOL=http
VITE_API_HOST=localhost
VITE_API_PORT=8080
VITE_API_BASE=/api/orders
# Token Bearer opzionale (solo se gli endpoint diventano protetti)
VITE_API_TOKEN=

# ── Porta del dev server del tabellone ──────────────────────────────────────
VITE_PORT=5180

# ── Polling ──────────────────────────────────────────────────────────────────
VITE_POLL_MS=8000

# ── Forma della chiamata di cambio stato (se il DTO cambia) ─────────────────
# mode: "query" (default, ...?status=READY) oppure "body" ({ "status": "READY" })
VITE_STATUS_MODE=query
VITE_STATUS_PARAM=status

# ── Soglie attesa (minuti) per evidenziare gli ordini in ritardo ────────────
VITE_WAIT_WARNING=8
VITE_WAIT_DANGER=15
