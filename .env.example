# =============================================================================
#  Variabili dello stack globale (docker-compose).
#  Copia questo file in ".env" e personalizza. Tutte hanno un default sensato.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=bcc
# Imposta una password (NON committare il .env reale)
POSTGRES_PASSWORD=changeme
POSTGRES_DB=blue_crystal_db

# --- RabbitMQ ---
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- JWT condiviso tra backend (8080) e servizio notifiche (8085) ---
# DEVE essere identico ai due servizi. Genera una chiave Base64 da >=32 byte, es:
#   openssl rand -base64 32
BE_APP_JWTSECRET=

# --- Porte pubblicate sull'host ---
ADMIN_PORT=8090
MANAGER_PORT=5185
CUCINA_PORT=5183
TABELLONE_PORT=5180
CASSA_PORT=8081
BACKEND_PORT=8080
NOTIFICATION_PORT=8085
RABBITMQ_AMQP_PORT=5672
RABBITMQ_UI_PORT=15672
POSTGRES_PORT=5432

# --- Cucina: token-stazione della sede gestita (copialo dal pannello Admin → Sedi).
# Necessario perché la cucina possa cambiare lo stato degli ordini di quella sede.
VITE_STATION_TOKEN=

# --- Firebase (push) per admin e manager. Lasciare vuoto se non si usa il push.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=
