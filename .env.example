# Copia in ".env" e personalizza (tutte hanno un default sensato).

# PostgreSQL
POSTGRES_USER=bcc
POSTGRES_PASSWORD=changeme
POSTGRES_DB=blue_crystal_db

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# JWT condiviso (genera con: openssl rand -base64 32)
BE_APP_JWTSECRET=

# Porte host
BACKEND_PORT=8080
POSTGRES_PORT=5432
RABBITMQ_AMQP_PORT=5672
RABBITMQ_UI_PORT=15672
