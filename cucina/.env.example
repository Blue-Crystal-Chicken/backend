# ============================================================================
#  Cucina (KDS) — configurazione ambiente
#  Copia questo file in ".env" e modifica solo cio' che serve.
# ============================================================================

# ── Backend (cambia SOLO la porta per puntare a un altro ambiente) ──────────
VITE_API_PROTOCOL=http
VITE_API_HOST=localhost
VITE_API_PORT=8080
VITE_API_BASE=/api/orders
VITE_PRODUCTS_PATH=/api/products/v1/products

# Token Bearer: OBBLIGATORIO per i bottoni Fatto/Cancellato.
# Il PUT di cambio stato richiede ruolo ADMIN/operatore. Le GET sono pubbliche.
# (in dev il backend logga un Bearer admin pronto all'uso a ogni avvio)
VITE_API_TOKEN=

# ── Porta del dev server della cucina ───────────────────────────────────────
VITE_PORT=5183

# ── Polling ──────────────────────────────────────────────────────────────────
VITE_POLL_MS=6000

# ── Forma della chiamata di cambio stato (se il DTO cambia) ─────────────────
VITE_STATUS_MODE=query
VITE_STATUS_PARAM=status

# ── Soglie attesa (minuti) per evidenziare gli ordini in ritardo ────────────
VITE_WAIT_WARNING=6
VITE_WAIT_DANGER=12
