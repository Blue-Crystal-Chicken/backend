<configuration>

    <appender name="FILE"
              class="ch.qos.logback.core.rolling.RollingFileAppender">

        <!-- File attuale -->
        <file>logs/bcc.log</file>

        <!-- Rotazione -->
        <rollingPolicy
            class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">

            <!-- Nome file per data -->
            <fileNamePattern>
                logs/bcc-%d{yyyy-MM-dd}.log
            </fileNamePattern>

            <!-- Mantieni ultimi 30 giorni -->
            <maxHistory>30</maxHistory>

        </rollingPolicy>

        <!-- Formato -->
        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss} [%level] %msg%n
            </pattern>
        </encoder>

    </appender>

    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="FILE"/>
    </root>

</configuration>